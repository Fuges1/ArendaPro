<Window x:Class="ArendaPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArendaPro"
        Height="650"
        Width="1100"
        MinHeight="600"
        MinWidth="900">

    <Window.Resources>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="55"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ExitButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#EA4335"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ШАПКА -->

        <Border Grid.Row="0"
                Background="#F8F9FA"
                BorderBrush="#DDDDDD"
                BorderThickness="0,0,0,1">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0">

                    <TextBlock Text="🚗"
                               FontSize="26"/>

                    <TextBlock Text="ArendaPro"
                               Margin="10,0,0,0"
                               FontSize="22"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- Уведомления -->

                <Border Grid.Column="1"
                        Background="#FFF4D7"
                        Height="40"
                        Margin="20,15"
                        CornerRadius="5">

                    <TextBlock Text="Нет новых уведомлений"
                               VerticalAlignment="Center"
                               Margin="15,0"/>
                </Border>

                <!-- Пользователь -->

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0">

                    <TextBlock 
                               Name="employee_fullname"
                               Text="Иван Иванов"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"/>

                    <TextBlock 
                               Name="employee_role"
                               Foreground="Gray"
                               FontSize="12"
                               HorizontalAlignment="Right"/>
                    <TextBlock 
                               Name="date"
                               Text="rfgdfgdfg"
                               Foreground="Gray"
                               FontSize="12"
                               HorizontalAlignment="Right">
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="0"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                </StackPanel>

            </Grid>

        </Border>

        <!-- ОСНОВНАЯ ОБЛАСТЬ -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- БОКОВОЕ МЕНЮ -->

            <Border Grid.Column="0"
                    Background="#F8F9FA"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,0,1,0">

                <DockPanel>

                    <Button 
                            Name="Exit"
                            Content="Выход"
                            Style="{StaticResource ExitButtonStyle}" Click="Button_Exit_Click"
                            DockPanel.Dock="Bottom"
                            Margin="10"/>

                    <ScrollViewer>

                        <StackPanel>

                            <Button 
                                    Name="Button_Table"
                                    Content="Таблицы"
                                    Style="{StaticResource MenuButtonStyle}" Click="Button_Table_Click"/>

                            <Button 
                                    Name="Avto"
                                    Content="Автомобили"
                                    Style="{StaticResource MenuButtonStyle}" Click="Button_Avto_Click"/>

                            <Button  
                                    Name="Client"
                                    Content="Клиенты"
                                    Style="{StaticResource MenuButtonStyle}" Click="Button_Client_Click"/>

                            <Button  
                                    Name="tarifi"
                                    Content="Тарифы"
                                    Style="{StaticResource MenuButtonStyle}" Click="Button_tarifi_Click"/>

                            <Button  
                                    Name="Dogovor"
                                    Content="Договоры"
                                    Style="{StaticResource MenuButtonStyle}" Click="Button_Dogovor_Click"/>

                            <Button  
                                    Name="OtherOborot"
                                    Content="Отчёты"
                                    Style="{StaticResource MenuButtonStyle}" Click="Button_OtherOborot_Click"/>

                            <Button  
                                    Name="Notification"
                                    Content="Уведомления"
                                    Style="{StaticResource MenuButtonStyle}" Click="Button_Notification_Click"/>

                            <Button  
                                    Name="Setting"
                                    Content="Настройки"
                                    Style="{StaticResource MenuButtonStyle}" Click="Button_Setting_Click"/>

                        </StackPanel>

                    </ScrollViewer>

                </DockPanel>

            </Border>

            <!-- РАБОЧАЯ ОБЛАСТЬ -->

            <Grid Grid.Column="1"
                  Margin="20">

                <Border Background="White"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        CornerRadius="5">

                    <StackPanel Margin="20">

                        <TextBlock Text="Главная панель"
                                   FontSize="26"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Здесь в будущем будет статистика, графики, список автомобилей, уведомления и другие элементы интерфейса."
                                   Margin="0,15,0,0"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="txtWorkerName"/>
                        <TextBlock x:Name="txtRoleInfo"/>

                        <TextBlock x:Name="txtEmail"
               Visibility="Collapsed"/>

                        <TextBlock x:Name="txtPassport"
               Visibility="Collapsed"/>

                        <TextBlock x:Name="txtPassportIssued"
               Visibility="Collapsed"/>

                        <TextBlock x:Name="txtPassportDate"
               Visibility="Collapsed"/>
                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>